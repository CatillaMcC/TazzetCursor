# Copy to .env and fill in values:  cp .env.example .env

# Required for AI features (server-side proxy; recommended for production)
ANTHROPIC_API_KEY=

# Optional: override default Claude model
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Server port (Render/Railway etc. usually set this automatically)
# PORT=3000

# Required in production — use a long random string (openssl rand -hex 32)
JWT_SECRET=

# PostgreSQL — enables auth, persistence, Google/email login
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# When using a remote DATABASE_URL, set to true only if your Node trust store
# validates the DB server certificate (otherwise connection may fail).
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Registration invite gate (optional — omit to allow open registration when DB is set)
# TAZZET_INVITE_CODE=

# Freepik API (optional — image search / generation)
# FREEPIK_API_KEY=

# Production safety: AI/Freepik proxy routes require a signed-in user (Bearer JWT).
# Set to true only for special cases (e.g. demo without a database). Never on public internet.
# ALLOW_ANONYMOUS_AI_PROXY=false
